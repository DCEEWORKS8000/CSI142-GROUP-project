package ub.com.CSI142.MotsheloSystem.app
  
import java.util.Scanner;

public class MainApp {
    public static void main(String[] args) {
         Scanner in=new Scanner(System.in);
         int choice;

         do{
        
         System.out.println("\n ********MOTSHELO SAVINGS SYSTEM********\n");
         System.out.println("1.Add member");
         System.out.println("2.Remove member");
         System.out.println("3.Show members");
         System.out.println("4.Add Contribution");
         System.out.println("5.Check contributions total");
         System.out.println("0.Exit");

         System.out.print("Choose option:");
         choice=in.nextInt();
         in.nextLine();
         
         switch (choice) {
            case 1:
                  system.addMember();
                  break;
            case 2:
                  system.removeMember();
                  break;
            case 3:
                   system.displayMembers();
                   break;
            case 4:
                   system.addContribution();
                   break;
            case 5:
                   system.getTotalContributions();
                   break;
            case 0:
                   System.out.print("Exiting");
                   break;
            default:
                   System.out.print("Invalid choice");
                   break;
         }
         }while (choice!=0); {
            
         }
    }
}
